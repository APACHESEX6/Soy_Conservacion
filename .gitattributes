# Normalizar line endings a LF en todos los archivos de texto
* text=auto eol=lf

# Source code
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.jsx   text eol=lf

# Config & data
*.json  text eol=lf
*.jsonc text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.env   text eol=lf

# Styles & markup
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf

# Database
*.sql   text eol=lf
*.prisma text eol=lf

# Shell scripts
*.sh    text eol=lf

# Windows scripts — mantener CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binarios — no tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
