{
  "name": "soy-conservacion",
  "version": "1.0.0",
  "description": "Plataforma de visualización de biodiversidad — Visor geoespacial con ETL integrado",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:frontend": "pnpm -F frontend dev",
    "dev:backend": "pnpm -F backend dev",
    "build": "turbo build",
    "quality": "turbo quality",
    "lint": "turbo lint",
    "lint:ci": "turbo lint:ci",
    "lint:fix": "turbo lint -- --write",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:ui": "turbo test -- --ui",
    "test:coverage": "turbo test -- --coverage",
    "validate": "turbo format:check lint:ci typecheck test build",
    "knip": "knip",
    "audit": "pnpm audit --prod",
    "audit:fix": "pnpm audit fix",
    "secrets-check": "git diff --cached --name-only | xargs grep -lE 'AIza[0-9A-Za-z-_]{35}|ghp_[0-9A-Za-z]{36}|xox[baprs]-[0-9]{12}-[0-9]{12}-[a-zA-Z0-9]{24}' || true",
    "setup": "chmod +x scripts/setup.sh && scripts/setup.sh",
    "clean": "chmod +x scripts/clean.sh && scripts/clean.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "lint-staged": "^16.4.0",
    "pnpm": "^10.33.2",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
