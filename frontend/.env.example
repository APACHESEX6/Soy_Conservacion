# ============================================================
#  FRONTEND — Variables de Entorno (Referencia)
#  Proyecto : Soy Conservación
# ============================================================
#  Copia este archivo como .env.local y completa los valores.
#  NUNCA incluyas credenciales reales en este archivo.
#  Las variables NEXT_PUBLIC_* son visibles en el cliente.
# ============================================================


# ── API BACKEND ───────────────────────────────────────────────────────────────
# URL base del backend. En producción reemplazar con el dominio real.

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000


# ── MAPBOX ────────────────────────────────────────────────────────────────────
# Token público de Mapbox GL JS.
# Restringir dominios permitidos en: https://account.mapbox.com/access-tokens

