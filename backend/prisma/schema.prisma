generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  idUsuario         Int                      @id @default(autoincrement()) @map("id_usuario")
  username          String                   @unique
  fechaRegistro     DateTime                 @default(now()) @map("fecha_registro")
  observacionesInat InaturalistObservacion[]
  observaciones     Observacion[]

  @@map("usuarios")
}

model GrupoTaxonomico {
  idGrupo  Int       @id @default(autoincrement()) @map("id_grupo")
  nombre   String
  especies Especie[]

  @@map("grupo_taxonomico")
}

model Especie {
  idEspecie         Int                      @id @default(autoincrement()) @map("id_especie")
  nombreCientifico  String                   @unique @map("nombre_cientifico")
  grupoTaxonomicoId Int                      @map("grupo_taxonomico")
  grupoTaxonomico   GrupoTaxonomico          @relation(fields: [grupoTaxonomicoId], references: [idGrupo])
  observacionesInat InaturalistObservacion[]
  observaciones     Observacion[]

  @@map("especies")
}

model Fuente {
  idFuente          Int                      @id @default(autoincrement()) @map("id_fuente")
  nombre            String
  observacionesInat InaturalistObservacion[]
  observaciones     Observacion[]

  @@map("fuente")
}

model Observacion {
  idObservacion Int      @id @default(autoincrement()) @map("id_observacion")
  usuarioId     Int      @map("id_usuario")
  especieId     Int      @map("id_especie")
  instanceId    String   @unique @map("instance_id")
  fecha         DateTime
  foto          String?
  audio         String?
  latitud       Float?
  longitud      Float?
  altitude      Float?
  accuracy      Float?
  fuenteId      Int      @map("id_fuente")
  especie       Especie  @relation(fields: [especieId], references: [idEspecie])
  fuente        Fuente   @relation(fields: [fuenteId], references: [idFuente])
  usuario       Usuario  @relation(fields: [usuarioId], references: [idUsuario])

  @@map("observaciones")
}

model InaturalistObservacion {
  idInaturalistObservacion Int      @id @default(autoincrement()) @map("id_inaturalist_observacion")
  usuarioId                Int      @map("id_usuario")
  especieId                Int      @map("id_especie")
  inaturalistId            String   @unique @map("inaturalist_id")
  fecha                    DateTime
  foto                     String?
  audio                    String?
  latitud                  Float?
  longitud                 Float?
  accuracy                 Float?
  urlInaturalist           String?  @map("url_inaturalist")
  qualityGrade             String?  @map("quality_grade")
  grupoTaxonomico          String?  @map("grupo_taxonomico")
  fuenteId                 Int      @map("id_fuente")
  especie                  Especie  @relation(fields: [especieId], references: [idEspecie])
  fuente                   Fuente   @relation(fields: [fuenteId], references: [idFuente])
  usuario                  Usuario  @relation(fields: [usuarioId], references: [idUsuario])

  @@map("inaturalist_observaciones")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}
