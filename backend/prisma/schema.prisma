generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  idUsuario         Int                      @id @default(autoincrement()) @map("id_usuario")
  username          String                   @unique
  fechaRegistro     DateTime                 @default(now()) @map("fecha_registro")
  observaciones     Observacion[]
  observacionesInat InaturalistObservacion[]

  @@map("usuarios")
}

model GrupoTaxonomico {
  idGrupo  Int       @id @default(autoincrement()) @map("id_grupo")
  nombre   String    @unique
  especies Especie[]
  observacionesInat InaturalistObservacion[]

  @@map("grupo_taxonomico")
}

model Especie {
  idEspecie         Int                      @id @default(autoincrement()) @map("id_especie")
  nombreCientifico  String                   @unique @map("nombre_cientifico")
  grupoTaxonomicoId Int                      @map("grupo_taxonomico")
  grupoTaxonomico   GrupoTaxonomico          @relation(fields: [grupoTaxonomicoId], references: [idGrupo], onDelete: Restrict, onUpdate: Cascade)
  observaciones     Observacion[]
  observacionesInat InaturalistObservacion[]

  @@index([grupoTaxonomicoId], map: "especies_grupo_taxonomico_idx")

  @@map("especies")
}

model Fuente {
  idFuente          Int                      @id @default(autoincrement()) @map("id_fuente")
  nombre            String                   @unique
  observaciones     Observacion[]
  observacionesInat InaturalistObservacion[]

  @@map("fuente")
}

model Observacion {
  idObservacion Int      @id @default(autoincrement()) @map("id_observacion")
  usuarioId     Int      @map("id_usuario")
  especieId     Int      @map("id_especie")
  instanceId    String   @unique @map("instance_id")
  fecha         DateTime
  foto          String?
  audio         String?
  latitud       Float?
  longitud      Float?
  altitude      Float?
  accuracy      Float?
  fuenteId      Int      @map("id_fuente")
  usuario       Usuario  @relation(fields: [usuarioId], references: [idUsuario], onDelete: Restrict, onUpdate: Cascade)
  especie       Especie  @relation(fields: [especieId], references: [idEspecie], onDelete: Restrict, onUpdate: Cascade)
  fuente        Fuente   @relation(fields: [fuenteId], references: [idFuente], onDelete: Restrict, onUpdate: Cascade)

  @@index([usuarioId], map: "observaciones_id_usuario_idx")
  @@index([especieId], map: "observaciones_id_especie_idx")
  @@index([fuenteId], map: "observaciones_id_fuente_idx")

  @@map("observaciones")
}

model InaturalistObservacion {
  idInaturalistObservacion Int      @id @default(autoincrement()) @map("id_inaturalist_observacion")
  usuarioId                Int      @map("id_usuario")
  especieId                Int      @map("id_especie")
  inaturalistId            String   @unique @map("inaturalist_id")
  fecha                    DateTime
  foto                     String?
  audio                    String?
  latitud                  Float?
  longitud                 Float?
  accuracy                 Float?
  urlInaturalist           String?  @map("url_inaturalist")
  qualityGrade             String?  @map("quality_grade")
  grupoTaxonomicoId        Int      @map("id_grupo")
  fuenteId                 Int      @map("id_fuente")
  usuario                  Usuario  @relation(fields: [usuarioId], references: [idUsuario], onDelete: Restrict, onUpdate: Cascade)
  especie                  Especie  @relation(fields: [especieId], references: [idEspecie], onDelete: Restrict, onUpdate: Cascade)
  grupoTaxonomico          GrupoTaxonomico @relation(fields: [grupoTaxonomicoId], references: [idGrupo], onDelete: Restrict, onUpdate: Cascade)
  fuente                   Fuente   @relation(fields: [fuenteId], references: [idFuente], onDelete: Restrict, onUpdate: Cascade)

  @@index([usuarioId], map: "inaturalist_observaciones_id_usuario_idx")
  @@index([especieId], map: "inaturalist_observaciones_id_especie_idx")
  @@index([grupoTaxonomicoId], map: "inaturalist_observaciones_id_grupo_idx")
  @@index([fuenteId], map: "inaturalist_observaciones_id_fuente_idx")

  @@map("inaturalist_observaciones")
}
