  "main": "dist/server.js",
  "scripts": {
    "dev": "node scripts/dev-backend.mjs",
    "dev:server": "nodemon --watch src --ext ts --exec \"ts-node src/server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:db-push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "etl:run-once": "ts-node src/etl/runOnce.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src scripts",
    "lint:ci": "biome check src scripts --error-on-warnings",
    "quality": "pnpm format:check && pnpm lint:ci && pnpm prisma validate && pnpm prisma:generate && pnpm typecheck && pnpm build",
    "lint:fix": "biome check src scripts --write",
    "format": "biome format src scripts --write",
    "format:check": "biome format src scripts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
