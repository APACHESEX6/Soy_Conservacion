# ============================================================
#  BACKEND — Variables de Entorno (Referencia)
#  Proyecto : Soy Conservación
# ============================================================
#  Copia este archivo como .env y completa los valores.
#  NUNCA incluyas credenciales reales en este archivo.
# ============================================================


# ── SERVIDOR ─────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000


# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
# PostgreSQL con extensión PostGIS requerida.
# Formato: postgresql://<user>:<password>@<host>:<port>/<db>?schema=<schema>

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soy_conservacion?schema=public


# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma.
# En producción reemplazar con el dominio real del frontend.

CORS_ORIGINS=http://localhost:3000


# ── RATE LIMITING ─────────────────────────────────────────────────────────────
# Ventana de tiempo en ms y máximo de peticiones por IP en esa ventana.

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120


# ── BODY PARSER ───────────────────────────────────────────────────────────────

JSON_BODY_LIMIT=1mb


# ── ETL — GENERAL ─────────────────────────────────────────────────────────────
# ETL_RUN_ON_START : ejecuta una ingesta completa al arrancar el servidor.
# ETL_TIMEZONE     : zona horaria para los cron jobs (formato IANA).
# ETL_CONCURRENCY  : operaciones de DB en paralelo por lote.

ETL_RUN_ON_START=true
ETL_TIMEZONE=America/Bogota
ETL_CONCURRENCY=4
ETL_PREFETCH_CHUNK_SIZE=500


# ── ETL — GOOGLE DRIVE (Excel) ────────────────────────────────────────────────
# Mantener DRIVE_ETL_ENABLED=false hasta tener las credenciales del cliente.
# Puedes usar GOOGLE_SERVICE_ACCOUNT_JSON con el JSON completo o
# GOOGLE_SERVICE_ACCOUNT_FILE para la ruta local a un archivo JSON.

DRIVE_ETL_ENABLED=false
DRIVE_ETL_CRON=*/30 * * * *
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=./google-drive-service-account.json


# ── ETL — INATURALIST ─────────────────────────────────────────────────────────
# INAT_FULL_SYNC=true  → descarga todas las observaciones del proyecto.
# INAT_FULL_SYNC=false → solo observaciones actualizadas en los últimos
#                        INAT_LOOKBACK_MINUTES minutos (modo incremental).

INAT_ETL_ENABLED=true
INAT_ETL_CRON=15 * * * *
INAT_API_BASE_URL=https://api.inaturalist.org/v1
INAT_PROJECT_ID=
INAT_PER_PAGE=200
INAT_MAX_PAGES=50
INAT_FULL_SYNC=true
INAT_LOOKBACK_MINUTES=120
INAT_HTTP_RETRIES=3
INAT_HTTP_TIMEOUT_MS=15000
INAT_USER_AGENT=soy-conservacion-backend/1.0


# ── MAPBOX ────────────────────────────────────────────────────────────────────
# Token de acceso a Mapbox para geocoding inverso.
MAPBOX_ACCESS_TOKEN=


# ── CACHÉ GEOJSON ─────────────────────────────────────────────────────────────
# Caché en memoria para respuestas GeoJSON del endpoint de observaciones.
# OBS_GEOJSON_CACHE_TTL_MS : tiempo de vida de cada entrada en ms.
# OBS_GEOJSON_CACHE_MAX    : máximo de entradas simultáneas en caché.

OBS_GEOJSON_CACHE_ENABLED=true
OBS_GEOJSON_CACHE_TTL_MS=60000
OBS_GEOJSON_CACHE_MAX=200
OBS_GEOJSON_USE_POSTGIS=true
